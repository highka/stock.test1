import requests
import pandas as pd
import time
from datetime import datetime, timedelta

def get_twse_institutional_data(date_str):
    """
    爬取台灣證交所(TWSE)特定日期的三大法人買賣超彙總表
    :param date_str: 格式為 'YYYYMMDD'
    """
    url = f"https://www.twse.com.tw/fund/T86?response=json&date={date_str}&selectType=ALL"
    
    try:
        res = requests.get(url, timeout=10)
        data = res.json()
        
        # 檢查該日期是否有資料 (假日或未來日期會顯示 '很抱歉，沒有符合條件的資料!')
        if data['stat'] == 'OK':
            # 將 JSON 轉為 Pandas DataFrame
            df = pd.DataFrame(data['data'], columns=data['fields'])
            
            # 整理欄位：把字串中的逗號拿掉，並轉成數值格式
            for col in df.columns:
                if '股數' in col or '金額' in col:
                    df[col] = pd.to_numeric(df[col].str.replace(',', ''), errors='coerce')
            
            # 把「股數」換算成「張數」 (除以 1000)
            df['外資買賣超(張)'] = df['外陸資買賣超股數(不含外資自營商)'] / 1000
            df['投信買賣超(張)'] = df['投信買賣超股數'] / 1000
            
            # 只保留我們需要的欄位
            df = df[['證券代號', '證券名稱', '外資買賣超(張)', '投信買賣超(張)']]
            return df
        else:
            return None
    except Exception as e:
        print(f"抓取 {date_str} 失敗: {e}")
        return None

def get_recent_two_trading_days_data():
    """
    自動往回找，取得最近兩個有開盤交易日的資料
    """
    data_frames = {}
    current_date = datetime.now()
    
    print("⏳ 開始尋找最近兩個交易日的籌碼資料...")
    
    # 往前找最多 10 天，直到湊齊 2 天的資料
    for i in range(10):
        check_date = (current_date - timedelta(days=i)).strftime("%Y%m%d")
        df = get_twse_institutional_data(check_date)
        
        if df is not None:
            print(f"✅ 成功取得 {check_date} 資料！")
            data_frames[check_date] = df
            if len(data_frames) == 2:
                break
        
        time.sleep(1) # 溫和爬蟲，休息 1 秒
        
    if len(data_frames) < 2:
        print("❌ 無法取得足夠的交易日資料")
        return None, None
        
    # 將日期排序，分出「今天(T)」與「昨天(T-1)」
    sorted_dates = sorted(data_frames.keys())
    df_yesterday = data_frames[sorted_dates[0]]
    df_today = data_frames[sorted_dates[1]]
    
    return df_today, df_yesterday

def run_smart_money_strategy():
    # 1. 取得近兩日籌碼大表
    df_today, df_yesterday = get_recent_two_trading_days_data()
    
    if df_today is None or df_yesterday is None:
        return
        
    print("\n⏳ 資料合併與策略篩選中...")
    
    # 2. 將今天的表與昨天的表合併 (透過證券代號)
    df_merged = pd.merge(
        df_today, 
        df_yesterday, 
        on=['證券代號', '證券名稱'], 
        suffixes=('_今日', '_昨日')
    )
    
    # 3. 執行策略邏輯篩選
    # 條件A：外資連買兩天，且今天買超張數 >= 昨天 * 1.1
    cond_foreign = (df_merged['外資買賣超(張)_昨日'] > 0) & \
                   (df_merged['外資買賣超(張)_今日'] > 0) & \
                   (df_merged['外資買賣超(張)_今日'] >= df_merged['外資買賣超(張)_昨日'] * 1.1)
                   
    # 條件B：投信連買兩天，且今天買超張數 >= 昨天 * 1.1
    cond_trust = (df_merged['投信買賣超(張)_昨日'] > 0) & \
                 (df_merged['投信買賣超(張)_今日'] > 0) & \
                 (df_merged['投信買賣超(張)_今日'] >= df_merged['投信買賣超(張)_昨日'] * 1.1)
                 
    # 只要符合外資或投信其中一個，就抓出來
    df_filtered = df_merged[cond_foreign | cond_trust].copy()
    
    # 標記是誰買的
    def get_signal_maker(row):
        f_ok = row['外資買賣超(張)_昨日'] > 0 and row['外資買賣超(張)_今日'] >= row['外資買賣超(張)_昨日'] * 1.1
        t_ok = row['投信買賣超(張)_昨日'] > 0 and row['投信買賣超(張)_今日'] >= row['投信買賣超(張)_昨日'] * 1.1
        if f_ok and t_ok: return "🔥 外資+投信 雙引擎連買放大"
        elif f_ok: return "外資連買且放大"
        elif t_ok: return "投信連買且放大"
        return ""
        
    df_filtered['發動主力'] = df_filtered.apply(get_signal_maker, axis=1)
    
    # 整理最終顯示欄位
    final_cols = [
        '證券代號', '證券名稱', '發動主力', 
        '外資買賣超(張)_昨日', '外資買賣超(張)_今日', 
        '投信買賣超(張)_昨日', '投信買 মোহ超(張)_今日'
    ]
    df_final = df_filtered[final_cols].sort_values(by='投信買賣超(張)_今日', ascending=False)
    
    print(f"\n🎯 篩選完畢！共找到 {len(df_final)} 檔符合條件的股票：\n")
    # 將顯示格式整理好看一點
    pd.set_option('display.max_rows', None)
    pd.set_option('display.float_format', '{:.0f}'.format)
    print(df_final)

# 執行腳本
if __name__ == "__main__":
    run_smart_money_strategy()
